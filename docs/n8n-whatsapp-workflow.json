      ]
    },
    "Create Booking": { "main": [[{ "node": "Save Conversation State", "type": "main", "index": 0 }]] },
    "Get Appointments": { "main": [[{ "node": "Save Conversation State", "type": "main", "index": 0 }]] },
    "Save Conversation State": { "main": [[{ "node": "Send WhatsApp Reply", "type": "main", "index": 0 }]] },
    "Send WhatsApp Reply": { "main": [[{ "node": "Respond 200", "type": "main", "index": 0 }]] },
    "Every 5 Minutes": { "main": [[{ "node": "Cancel Expired Bookings", "type": "main", "index": 0 }]] },
    "Cancel Expired Bookings": { "main": [[{ "node": "Any Expired?", "type": "main", "index": 0 }]] },
    "Any Expired?": { "main": [[{ "node": "Split Expired", "type": "main", "index": 0 }], []] },
    "Split Expired": { "main": [[{ "node": "Notify Expired Guest", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "meta": {
    "instanceId": "uppsalahalkbana-whatsapp-bot",
    "_readme": "ENVIRONMENT VARIABLES NEEDED IN n8n: SITE_URL (your site, e.g. https://uppsalahalkbana.se), WHATSAPP_API_KEY (same as in .env), WAHA_URL (your WAHA instance URL), WAHA_API_KEY (WAHA API key), WAHA_SESSION (default). Also set ANTHROPIC_API_KEY in Anthropic credentials."
  }
}
