generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  password         String
  phone            String?
  role             String    @default("student")
  hidden           Boolean   @default(false)
  languagePref     String    @default("sv")
  bookings         Booking[]
  schoolBookings   Booking[] @relation("BookingSchoolUser")
  assignedSessions Session[] @relation("AssignedSchoolSessions")
  schoolCoursePrices SchoolCoursePrice[]
  schoolAllocations  SessionSchoolAllocation[] @relation("SchoolAllocations")
  createdAt        DateTime  @default(now())
}

model School {
  id           Int       @id @default(autoincrement())
  name         String
  address      String
  contactEmail String
  sessions     Session[]
}

model Course {
  id          Int       @id @default(autoincrement())
  titleSv     String
  titleEn     String
  description String
  type        String
  vehicle     String
  behorighet  String    @default("B")
  price       Int
  location       String    @default("")
  receiptMessage String    @default("")
  sessions       Session[]
  schoolPrices   SchoolCoursePrice[]
}

model SchoolCoursePrice {
  id           Int    @id @default(autoincrement())
  schoolUserId Int
  schoolUser   User   @relation(fields: [schoolUserId], references: [id], onDelete: Cascade)
  courseId     Int
  course       Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  price        Int
  @@unique([schoolUserId, courseId])
}

model Session {
  id                   Int       @id @default(autoincrement())
  courseId             Int
  course               Course    @relation(fields: [courseId], references: [id])
  schoolId             Int
  school               School    @relation(fields: [schoolId], references: [id])
  startTime            DateTime
  endTime              DateTime
  seatLimit            Int
  seatsAvailable       Int
  visibility           String    @default("public")
  receiptMessage       String    @default("")
  assignedSchoolUsers  User[]    @relation("AssignedSchoolSessions")
  bookings             Booking[]
  schoolAllocations    SessionSchoolAllocation[]
}

model SessionSchoolAllocation {
  id             Int     @id @default(autoincrement())
  sessionId      Int
  session        Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  schoolUserId   Int
  schoolUser     User    @relation("SchoolAllocations", fields: [schoolUserId], references: [id], onDelete: Cascade)
  allocatedSeats Int
  @@unique([sessionId, schoolUserId])
}

model Booking {
  id           Int      @id @default(autoincrement())
  sessionId    Int
  session      Session  @relation(fields: [sessionId], references: [id])
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
  guestName    String?
  personnummer String?
  guestPhone   String?
  guestEmail   String?
  bookingTime          DateTime @default(now())
  status               String   @default("Pending")
  bookedByRole         String   @default("student")
  bookedBySchoolUserId Int?
  bookedBySchoolUser   User?    @relation("BookingSchoolUser", fields: [bookedBySchoolUserId], references: [id])
  reminderSentAt       DateTime?
  payment              Payment?
}

model Payment {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @unique
  booking       Booking  @relation(fields: [bookingId], references: [id])
  amount        Int
  provider      String
  status        String   @default("Pending")
  transactionId String?
  createdAt     DateTime @default(now())
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model CourseGroup {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}

model WhatsappNumber {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model WhatsappConversation {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  state     String   @default("idle")
  data      Json?
  updatedAt DateTime @updatedAt
}

model InfoCard {
  id                 Int      @id @default(autoincrement())
  badge              String   @default("")
  title              String
  description        String
  price              String   @default("")
  imageUrl           String   @default("")
  videoUrl           String   @default("")
  primaryButtonText  String   @default("Läs mer")
  primaryButtonLink  String   @default("/courses")
  secondaryButtonText String  @default("")
  secondaryButtonLink String  @default("")
  sortOrder          Int      @default(0)
  visible            Boolean  @default(true)
  createdAt          DateTime @default(now())
}
