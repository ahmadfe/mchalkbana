generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String
  phone        String?
  role         String    @default("student")
  languagePref String    @default("sv")
  bookings     Booking[]
  createdAt    DateTime  @default(now())
}

model School {
  id           Int       @id @default(autoincrement())
  name         String
  address      String
  contactEmail String
  sessions     Session[]
}

model Course {
  id          Int       @id @default(autoincrement())
  titleSv     String
  titleEn     String
  description String
  type        String
  vehicle     String
  price       Int
  sessions    Session[]
}

model Session {
  id             Int       @id @default(autoincrement())
  courseId       Int
  course         Course    @relation(fields: [courseId], references: [id])
  schoolId       Int
  school         School    @relation(fields: [schoolId], references: [id])
  startTime      DateTime
  endTime        DateTime
  seatLimit      Int
  seatsAvailable Int
  bookings       Booking[]
}

model Booking {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  session     Session  @relation(fields: [sessionId], references: [id])
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  bookingTime DateTime @default(now())
  status      String   @default("Pending")
  payment     Payment?
}

model Payment {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @unique
  booking       Booking  @relation(fields: [bookingId], references: [id])
  amount        Int
  provider      String
  status        String   @default("Pending")
  transactionId String?
  createdAt     DateTime @default(now())
}
